model User {
    id String @id @default(uuid())
    name String @db.VarChar(255)
    email String @unique
    password String
    role Role @default(CUSTOMER)
    status Status @default(ACTIVE)
    createdAt DateTime @default(now())  
    updatedAt DateTime @updatedAt

    technicianProfile TechnicianProfile?
    reviews Review[]

    bookings Booking[]
  


    @@map("users")
}

